# ============================================
# 小说优化系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env
# ============================================

# OpenAI API 配置（CLI 模式使用）
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_MODEL=qwen3.6:35b-mlx

# 整本小说模式：指定小说文件路径
# NOVEL_FILE=input/小说.txt

# Web 平台模式：每个模型的独立 API Key（可选，不配置则使用 OPENAI_API_KEY）
# MODEL_A_API_KEY=
# MODEL_B_API_KEY=
# MODEL_C_API_KEY=
# MODEL_D_API_KEY=
# MODEL_E_API_KEY=
# MODEL_F_API_KEY=

# 服务运行环境：development(开发模式, 默认) / production(生产模式, 禁用reload)
# ENV=development
# HOST=127.0.0.1
# PORT=8000
